# Public site URL (required for canonical URLs, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://www.fmfterminal.com

# Supabase Auth (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Vercel sets VERCEL_URL automatically in preview deployments
# NEXT_PUBLIC_SITE_URL is used in production — set in Vercel Project Settings

# Market data providers (candles)
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
# Yahoo / Binance public APIs need no keys
